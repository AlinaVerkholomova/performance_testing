        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Initialize Metrics" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.util.concurrent.ConcurrentLinkedQueue
import java.util.concurrent.atomic.LongAdder

props.put(&apos;put.total&apos;, new LongAdder())
props.put(&apos;put.errors&apos;, new LongAdder())
props.put(&apos;put.times&apos;, new ConcurrentLinkedQueue&lt;Long&gt;())
props.put(&apos;consistency.total&apos;, new LongAdder())
props.put(&apos;consistency.errors&apos;, new LongAdder())

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&apos;200&apos;)
SampleResult.setResponseMessage(&apos;Metrics initialized&apos;)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /api/v1/auth/login">
          <stringProp name="HTTPSampler.path">/api/v1/auth/login</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
  &quot;username&quot;: &quot;${ADMIN_USERNAME}&quot;,&#xd;
  &quot;password&quot;: &quot;${ADMIN_PASSWORD}&quot;&#xd;
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert Login 2xx" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def rc = prev.getResponseCode()
if (!(rc ==~ /2\d\d/)) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage(&quot;Expected HTTP 2xx for login but got ${rc}&quot;)
}
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223Assertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Auth Token" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def json = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())
def token = json?.token ?: json?.access_token
if (token == null || token.toString().trim().isEmpty()) {
  throw new AssertionError(&apos;Authentication token not found in /api/v1/auth/login response&apos;)
}
props.put(&apos;AUTH_TOKEN&apos;, token.toString())
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
      </hashTree>
