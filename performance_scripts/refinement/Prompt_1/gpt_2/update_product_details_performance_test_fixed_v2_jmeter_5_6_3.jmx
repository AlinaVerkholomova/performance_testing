                <stringProp name="Argument.value">{&#xd;
  &quot;name&quot;: &quot;${product_name}&quot;,&#xd;
  &quot;description&quot;: &quot;${product_description}&quot;,&#xd;
  &quot;price&quot;: ${product_price},&#xd;
  &quot;stock&quot;: ${product_stock}&#xd;
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
        </HTTPSamplerProxy>
