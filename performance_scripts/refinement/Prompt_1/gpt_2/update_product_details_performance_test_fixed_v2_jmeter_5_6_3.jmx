          </JSR223Assertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Aggregate PUT Metrics">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def total = props.get(&apos;put.total&apos;)
def errors = props.get(&apos;put.errors&apos;)
def times = props.get(&apos;put.times&apos;)
total.increment()
if (!prev.isSuccessful()) {
  errors.increment()
}
times.add(prev.getTime() as Long)
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223PostProcessor>
