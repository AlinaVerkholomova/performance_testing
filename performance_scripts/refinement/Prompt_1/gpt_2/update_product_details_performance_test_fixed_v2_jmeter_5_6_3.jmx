        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Prepare Product Data">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
def ids = vars.get(&apos;PRODUCT_IDS&apos;).split(&apos;,&apos;).collect { it.trim() }.findAll { it }
if (ids.isEmpty()) {
  throw new IllegalStateException(&apos;PRODUCT_IDS must contain at least one existing product_id&apos;)
}
def productId = ids[ctx.getThreadNum() % ids.size()]
def suffix = System.currentTimeMillis().toString() + &apos;_&apos; + ctx.getThreadNum() + &apos;_&apos; + UUID.randomUUID().toString().replace(&apos;-&apos;, &apos;&apos;).substring(0, 6)
vars.put(&apos;product_id&apos;, productId)
vars.put(&apos;product_name&apos;, &apos;Wireless Headphones &apos; + suffix)
vars.put(&apos;product_description&apos;, &apos;Noise-cancelling over-ear headphones &apos; + suffix)
vars.put(&apos;product_price&apos;, &apos;79.99&apos;)
vars.put(&apos;product_stock&apos;, &apos;50&apos;)
            </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PUT /api/v1/products/{product_id}">
          <stringProp name="HTTPSampler.path">/api/v1/products/${product_id}</stringProp>
          <stringProp name="HTTPSampler.method">PUT</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
