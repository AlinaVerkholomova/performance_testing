      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Evaluate NFRs">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">def total = props.get(&apos;put.total&apos;)
def errors = props.get(&apos;put.errors&apos;)
def queue = props.get(&apos;put.times&apos;)

long totalCount = total != null ? total.sum() : 0L
long errorCount = errors != null ? errors.sum() : 0L

def times = []
if (queue != null) { 
    times.addAll(queue) 
}
Collections.sort(times)

long p90 = 0L
if (times.size() &gt; 0) {
    int index = Math.ceil(times.size() * 0.90d) as int
    index = Math.max(1, index) - 1
    p90 = (times[index] as Number).longValue()
}

double errorRate = totalCount &gt; 0 ? (errorCount * 100.0d / totalCount) : 100.0d

boolean p90Pass = p90 &lt;= 700L
boolean errorPass = errorRate &lt; 1.0d

def summary = &quot;NFR Evaluation Summary\n&quot; +
&quot;put_total_samples=${totalCount}\n&quot; +
&quot;put_error_count=${errorCount}\n&quot; +
&quot;put_error_rate_pct=${String.format(&apos;%.4f&apos;, errorRate)}\n&quot; +
&quot;put_p90_ms=${p90}\n&quot; +
&quot;threshold_put_p90_ms&lt;=700 =&gt; ${p90Pass}\n&quot; +
&quot;threshold_put_error_rate_pct&lt;1 =&gt; ${errorPass}\n&quot;

SampleResult.setResponseData(summary, &apos;UTF-8&apos;)

if (totalCount == 0L) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&apos;500&apos;)
    SampleResult.setResponseMessage(&apos;No PUT samples were collected&apos;)
    throw new AssertionError(&apos;No PUT samples were collected for /api/v1/products/{product_id}&apos;)
}

if (!(p90Pass &amp;&amp; errorPass)) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&apos;500&apos;)
    SampleResult.setResponseMessage(&apos;NFR validation failed&apos;)
    throw new AssertionError(summary)
}

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&apos;200&apos;)
SampleResult.setResponseMessage(&apos;All NFR thresholds passed&apos;)
SampleResult.setResponseData(summary, &apos;UTF-8&apos;)
log.info(summary)</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
