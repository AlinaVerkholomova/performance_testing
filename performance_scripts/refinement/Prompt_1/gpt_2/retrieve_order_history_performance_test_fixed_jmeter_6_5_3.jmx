          <stringProp name="script">
vars.put(&apos;history_user_id&apos;, vars.get(&apos;ORDER_USER_ID&apos;))
vars.put(&apos;history_start_date&apos;, vars.get(&apos;START_DATE&apos;))
vars.put(&apos;history_end_date&apos;, vars.get(&apos;END_DATE&apos;))
