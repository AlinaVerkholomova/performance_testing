      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Initialize Metrics">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.util.concurrent.ConcurrentLinkedQueue
import java.util.concurrent.atomic.AtomicLong
import java.util.concurrent.atomic.LongAdder
props.put(&apos;history.total&apos;, new LongAdder())
props.put(&apos;history.errors&apos;, new LongAdder())
props.put(&apos;history.times&apos;, new ConcurrentLinkedQueue&lt;Long&gt;())
props.put(&apos;history.sum&apos;, new LongAdder())
props.put(&apos;history.firstSampleTs&apos;, new AtomicLong(0L))
props.put(&apos;history.lastSampleTs&apos;, new AtomicLong(0L))
SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&apos;200&apos;)
SampleResult.setResponseMessage(&apos;Metrics initialized&apos;)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
