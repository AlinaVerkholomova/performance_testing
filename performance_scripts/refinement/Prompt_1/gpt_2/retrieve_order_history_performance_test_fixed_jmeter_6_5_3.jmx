    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Retrieve Order History Performance Test - POST /api/v1/orders/history">
      <stringProp name="TestPlan.comments">Validate order history retrieval via POST /api/v1/orders/history using filtered queries, ensuring average response time, p95 latency, error rate, and throughput meet the NFR targets under a steady read load.</stringProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
