        <hashTree>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert POST 2xx Response">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def rc = prev.getResponseCode()
if (!(rc ==~ /2\d\d/)) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage(&quot;Expected HTTP 2xx for POST /api/v1/orders/history but got ${rc}&quot;)
}
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223Assertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Aggregate Metrics">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import java.util.concurrent.atomic.AtomicLong
import java.util.concurrent.atomic.LongAdder
LongAdder total = props.get(&apos;history.total&apos;) as LongAdder
LongAdder errors = props.get(&apos;history.errors&apos;) as LongAdder
LongAdder sum = props.get(&apos;history.sum&apos;) as LongAdder
def times = props.get(&apos;history.times&apos;)
AtomicLong firstTs = props.get(&apos;history.firstSampleTs&apos;) as AtomicLong
AtomicLong lastTs = props.get(&apos;history.lastSampleTs&apos;) as AtomicLong
long sampleStart = prev.getStartTime()
long sampleEnd = prev.getEndTime()
long sampleTime = prev.getTime()
total.increment()
sum.add(sampleTime)
if (!prev.isSuccessful()) { errors.increment() }
times.add(sampleTime as Long)
while (true) {
  long cur = firstTs.get()
  if (cur != 0L &amp;&amp; cur &lt;= sampleStart) { break }
  if (firstTs.compareAndSet(cur, sampleStart)) { break }
}
while (true) {
  long cur = lastTs.get()
  if (cur &gt;= sampleEnd) { break }
  if (lastTs.compareAndSet(cur, sampleEnd)) { break }
}
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="TearDown - Validate NFRs">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Evaluate NFRs">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.util.concurrent.atomic.AtomicLong
import java.util.concurrent.atomic.LongAdder
LongAdder total = props.get(&apos;history.total&apos;) as LongAdder
LongAdder errors = props.get(&apos;history.errors&apos;) as LongAdder
LongAdder sum = props.get(&apos;history.sum&apos;) as LongAdder
def queue = props.get(&apos;history.times&apos;)
AtomicLong firstTs = props.get(&apos;history.firstSampleTs&apos;) as AtomicLong
AtomicLong lastTs = props.get(&apos;history.lastSampleTs&apos;) as AtomicLong
long totalCount = total != null ? total.sum() : 0L
long errorCount = errors != null ? errors.sum() : 0L
long totalTime = sum != null ? sum.sum() : 0L
def times = []
if (queue != null) { times.addAll(queue) }
Collections.sort(times)
long p95 = 0L
if (times.size() &gt; 0) {
  int index = Math.ceil(times.size() * 0.95d) as int
  index = Math.max(1, index) - 1
  p95 = (times[index] as Number).longValue()
}
double avgResponseTime = totalCount &gt; 0 ? (totalTime * 1.0d / totalCount) : 0.0d
double errorRate = totalCount &gt; 0 ? (errorCount * 100.0d / totalCount) : 100.0d
long first = firstTs != null ? firstTs.get() : 0L
long last = lastTs != null ? lastTs.get() : 0L
double elapsedSec = (first &gt; 0L &amp;&amp; last &gt; first) ? ((last - first) / 1000.0d) : 0.0d
double throughput = elapsedSec &gt; 0 ? (totalCount / elapsedSec) : 0.0d
boolean avgPass = avgResponseTime &lt;= 300.0d
boolean p95Pass = p95 &lt;= 600L
boolean errorPass = errorRate &lt; 0.5d
boolean throughputPass = throughput &gt;= 100.0d
def summary = &quot;NFR Evaluation Summary\n&quot; +
&quot;total_samples=${totalCount}\n&quot; +
&quot;error_count=${errorCount}\n&quot; +
&quot;avg_response_time_ms=${String.format(&apos;%.4f&apos;, avgResponseTime)}\n&quot; +
&quot;p95_latency_ms=${p95}\n&quot; +
&quot;error_rate_pct=${String.format(&apos;%.4f&apos;, errorRate)}\n&quot; +
&quot;throughput_rps=${String.format(&apos;%.4f&apos;, throughput)}\n&quot; +
&quot;threshold_avg_response_time_ms&lt;=300 =&gt; ${avgPass}\n&quot; +
&quot;threshold_p95_latency_ms&lt;=600 =&gt; ${p95Pass}\n&quot; +
&quot;threshold_error_rate_pct&lt;0.5 =&gt; ${errorPass}\n&quot; +
&quot;threshold_throughput_rps&gt;=100 =&gt; ${throughputPass}\n&quot;
SampleResult.setResponseData(summary, &apos;UTF-8&apos;)
if (totalCount == 0L) {
  SampleResult.setSuccessful(false)
  SampleResult.setResponseCode(&apos;500&apos;)
  SampleResult.setResponseMessage(&apos;No samples were collected&apos;)
  throw new AssertionError(&apos;No samples were collected for /api/v1/orders/history&apos;)
}
if (!(avgPass &amp;&amp; p95Pass &amp;&amp; errorPass &amp;&amp; throughputPass)) {
  SampleResult.setSuccessful(false)
  SampleResult.setResponseCode(&apos;500&apos;)
  SampleResult.setResponseMessage(&apos;NFR validation failed&apos;)
  throw new AssertionError(summary)
}
SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&apos;200&apos;)
SampleResult.setResponseMessage(&apos;All NFR thresholds passed&apos;)
log.info(summary)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
