      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Initialize Global Metrics" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">
import java.util.concurrent.ConcurrentLinkedQueue
import java.util.concurrent.atomic.AtomicLong
import java.util.concurrent.atomic.LongAdder

props.put(&apos;patch.total&apos;, new LongAdder())
props.put(&apos;patch.errors&apos;, new LongAdder())
props.put(&apos;patch.times&apos;, new ConcurrentLinkedQueue&lt;Long&gt;())
props.put(&apos;patch.firstSampleTs&apos;, new AtomicLong(0L))
props.put(&apos;patch.lastSampleTs&apos;, new AtomicLong(0L))
props.put(&apos;patch.consistency.total&apos;, new LongAdder())
props.put(&apos;patch.consistency.errors&apos;, new LongAdder())

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&apos;200&apos;)
SampleResult.setResponseMessage(&apos;Metrics initialized&apos;)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
        </JSR223Sampler>
