      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown TG – NFR Threshold Validation">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">stoptest</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="NFR Validation – P95, Error Rate, Throughput">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// ─────────────────────────────────────────────────────────────────────────────
// NFR Post-Run Validation
//
// Validates POST /api/v1/users/register against:
//   1. P95 Response Time  &lt;= 500 ms
//   2. Error Rate         &lt;  1 %
//   3. Throughput         &gt;= 150 req/s
//
// Primary source:  in-memory metric collections (JSR223PostProcessor)
// Fallback source: results/summary_report.csv
// ─────────────────────────────────────────────────────────────────────────────
import org.apache.jmeter.samplers.SampleResult

long   nfrP95Ms  = (vars?.get(&quot;NFR_P95_MS&quot;)?.toLong()           ?: 500L)
double nfrErrPct = (vars?.get(&quot;NFR_ERROR_RATE_PCT&quot;)?.toDouble() ?: 1.0)
double nfrTpRps  = (vars?.get(&quot;NFR_THROUGHPUT_RPS&quot;)?.toDouble() ?: 150.0)

def    rtList    = props.get(&quot;reg_rt_list&quot;)
def    totalAt   = props.get(&quot;reg_total&quot;)
def    errorsAt  = props.get(&quot;reg_errors&quot;)
def    startMs   = props.get(&quot;reg_start_epoch&quot;)

long   total     = 0L
long   errors    = 0L
long   p95       = 0L
double tpRps     = 0.0
boolean usedCsv  = false

if (rtList != null &amp;&amp; !rtList.isEmpty()) {
    // ── In-memory path ───────────────────────────────────────────────────────
    def snapshot = new ArrayList(rtList)
    total  = totalAt?.get()  ?: (long) snapshot.size()
    errors = errorsAt?.get() ?: 0L

    snapshot.sort()
    int p95Idx = (int) Math.ceil(0.95 * snapshot.size()) - 1
    p95 = snapshot[Math.max(0, p95Idx)]

    if (startMs) {
        double elapsedSec = (System.currentTimeMillis() - (long) startMs) / 1000.0
        tpRps = elapsedSec &gt; 0 ? total / elapsedSec : 0.0
    }

} else {
    // ── CSV fallback ─────────────────────────────────────────────────────────
    usedCsv = true
    def f = new File(&quot;results/summary_report.csv&quot;)
    if (!f.exists()) {
        log.warn(&quot;NFR Validation: no in-memory data and no CSV found – skipping&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: no metrics source available&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    def lines      = f.readLines()
    def header     = lines[0].split(&quot;,&quot;).collect { it.trim().toLowerCase() }
    def labelIdx   = header.indexOf(&quot;label&quot;)
    def timeIdx    = header.indexOf(&quot;elapsed&quot;)
    def successIdx = header.indexOf(&quot;success&quot;)
    def tsIdx      = header.indexOf(&quot;timestamp&quot;)

    if (labelIdx == -1 || timeIdx == -1) {
        log.warn(&quot;NFR Validation: required columns missing in CSV&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: CSV column mapping failed&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    def times  = []
    long minTs = Long.MAX_VALUE
    long maxTs = Long.MIN_VALUE

    lines.drop(1).each { line -&gt;
        if (!line.trim()) return
        def cols  = line.split(&quot;,&quot;, -1)
        def label = cols[labelIdx]?.trim()
        if (!label?.contains(&quot;register&quot;) &amp;&amp; !label?.contains(&quot;TX-01&quot;)) return
        total++
        try {
            def rt = cols[timeIdx]?.trim()?.toLong()
            if (rt != null) times &lt;&lt; rt
            if (tsIdx &gt;= 0) {
                def ts = cols[tsIdx]?.trim()?.toLong()
                if (ts != null) {
                    if (ts &lt; minTs) minTs = ts
                    if (ts &gt; maxTs) maxTs = ts
                }
            }
        } catch (e) {}
        if (cols[successIdx]?.trim()?.toLowerCase() == &quot;false&quot;) errors++
    }

    if (total == 0) {
        log.warn(&quot;NFR Validation: no register samples found in CSV&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: no POST /users/register samples found&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    times.sort()
    int p95Idx = (int) Math.ceil(0.95 * times.size()) - 1
    p95 = times[Math.max(0, p95Idx)]

    if (minTs &lt; Long.MAX_VALUE &amp;&amp; maxTs &gt; Long.MIN_VALUE) {
        double elapsedSec = (maxTs - minTs) / 1000.0
        tpRps = elapsedSec &gt; 0 ? total / elapsedSec : 0.0
    }
}

double errorRatePct = total &gt; 0 ? (errors / (double) total) * 100.0 : 0.0

boolean p95Pass = p95          &lt;= nfrP95Ms
boolean errPass = errorRatePct  &lt;  nfrErrPct
boolean tpPass  = tpRps         &gt;= nfrTpRps

def sb = new StringBuilder()
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
sb.append(&quot;  NFR VALIDATION REPORT – User Registration\n&quot;)
sb.append(&quot;  POST /api/v1/users/register   (source: ${usedCsv ? &apos;CSV&apos; : &apos;in-memory&apos;})\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
sb.append(&quot;  Total samples       : ${total}\n&quot;)
sb.append(&quot;  Failed samples      : ${errors}\n&quot;)
sb.append(String.format(&quot;  Error rate          : %.3f%%  (target: &lt; %.1f%%)   [%s]\n&quot;,
          errorRatePct, nfrErrPct, errPass ? &quot;PASS&quot; : &quot;FAIL&quot;))
sb.append(&quot;  P95 response time   : ${p95} ms  (target: &lt;= ${nfrP95Ms} ms)   [${p95Pass ? &apos;PASS&apos; : &apos;FAIL&apos;}]\n&quot;)
sb.append(String.format(&quot;  Throughput          : %.2f req/s  (target: &gt;= %.0f req/s)   [%s]\n&quot;,
          tpRps, nfrTpRps, tpPass ? &quot;PASS&quot; : &quot;FAIL&quot;))
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
boolean overall = p95Pass &amp;&amp; errPass &amp;&amp; tpPass
sb.append(&quot;  OVERALL NFR RESULT  : ${overall ? &apos;PASS&apos; : &apos;FAIL&apos;}\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)

log.info(sb.toString())
SampleResult.setResponseData(sb.toString(), &quot;UTF-8&quot;)
SampleResult.setResponseMessage(sb.toString())
SampleResult.setSuccessful(overall)

if (!p95Pass) log.error(&quot;NFR BREACH: P95 = ${p95}ms exceeds threshold of ${nfrP95Ms}ms&quot;)
if (!errPass) log.error(String.format(&quot;NFR BREACH: Error rate = %.3f%% exceeds threshold of %.1f%%&quot;,
              errorRatePct, nfrErrPct))
if (!tpPass)  log.error(String.format(&quot;NFR BREACH: Throughput = %.2f req/s below threshold of %.0f req/s&quot;,
              tpRps, nfrTpRps))
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
