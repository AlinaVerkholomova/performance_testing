          <elementProp name="NFR_P95_MS" elementType="Argument">
            <stringProp name="Argument.name">NFR_P95_MS</stringProp>
            <stringProp name="Argument.value">500</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="NFR_ERROR_RATE_PCT" elementType="Argument">
            <stringProp name="Argument.name">NFR_ERROR_RATE_PCT</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="NFR_THROUGHPUT_RPS" elementType="Argument">
            <stringProp name="Argument.name">NFR_THROUGHPUT_RPS</stringProp>
            <stringProp name="Argument.value">150</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="MAX_VUS" elementType="Argument">
