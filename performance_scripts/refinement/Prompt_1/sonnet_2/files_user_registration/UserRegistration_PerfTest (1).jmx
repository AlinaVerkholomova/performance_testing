            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 – Accumulate runtime metrics" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
props.get(&quot;reg_rt_list&quot;)?.add(prev.getTime())
props.get(&quot;reg_total&quot;)?.incrementAndGet()
if (!prev.isSuccessful()) props.get(&quot;reg_errors&quot;)?.incrementAndGet()
