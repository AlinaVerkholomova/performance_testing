      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init – results dir and shared collections">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
new File(&quot;results&quot;).mkdirs()

// Thread-safe metric accumulators for post-run NFR validation
props.put(&quot;reg_rt_list&quot;,       Collections.synchronizedList([]))
props.put(&quot;reg_total&quot;,         new java.util.concurrent.atomic.AtomicLong(0L))
props.put(&quot;reg_errors&quot;,        new java.util.concurrent.atomic.AtomicLong(0L))
props.put(&quot;reg_start_epoch&quot;,   System.currentTimeMillis())

// Global atomic counter for guaranteed-unique sequence numbers
// Combined with thread ID and timestamp this ensures zero email collisions
props.put(&quot;reg_seq_counter&quot;,   new java.util.concurrent.atomic.AtomicLong(0L))

log.info(&quot;setUp complete – results/ ready, metric stores initialised&quot;)
SampleResult.setResponseMessage(&quot;setUp complete&quot;)
SampleResult.setSuccessful(true)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
