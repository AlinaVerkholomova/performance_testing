        <longProp name="ThreadGroup.delay">0</longProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <intProp name="LoopController.loops">-1</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 – Generate unique username and email">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// ── Uniqueness strategy ───────────────────────────────────────────────────────
// Combines three entropy sources to guarantee no duplicate email across
// the full 300s run at 150+ req/s:
//   1. epoch milliseconds       – coarse timestamp
//   2. JMeter thread number     – unique per VU
//   3. global atomic sequence   – unique per iteration within the VU
//
// Pattern matches the input spec:  &quot;test_user&lt;ts&gt;&quot; / &quot;test&lt;ts&gt;@example.com&quot;
// ─────────────────────────────────────────────────────────────────────────────

long   ts      = System.currentTimeMillis()
int    tid     = ctx.getThreadNum()
long   seq     = props.get(&quot;reg_seq_counter&quot;).incrementAndGet()

// Compact unique suffix:  ms_threadId_globalSeq
String suffix  = &quot;${ts}_${tid}_${seq}&quot;

vars.put(&quot;REG_USERNAME&quot;,  &quot;test_user${suffix}&quot;)
vars.put(&quot;REG_EMAIL&quot;,     &quot;test${suffix}@example.com&quot;)
vars.put(&quot;CORRELATION_ID&quot;, UUID.randomUUID().toString())
vars.put(&quot;TIMESTAMP&quot;,      String.valueOf(ts))
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
