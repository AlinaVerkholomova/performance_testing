        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Initialize Global Metrics" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.util.concurrent.atomic.LongAdder
import java.util.concurrent.atomic.AtomicLong

props.put(&apos;delete.total&apos;, new LongAdder())
props.put(&apos;delete.errors&apos;, new LongAdder())
props.put(&apos;delete.max&apos;, new AtomicLong(0L))
props.put(&apos;delete.integrity.total&apos;, new LongAdder())
props.put(&apos;delete.integrity.errors&apos;, new LongAdder())

SampleResult.setResponseCode(&apos;200&apos;)
SampleResult.setResponseMessage(&apos;Soft delete metrics initialized&apos;)
SampleResult.setSuccessful(true)
          </stringProp>
