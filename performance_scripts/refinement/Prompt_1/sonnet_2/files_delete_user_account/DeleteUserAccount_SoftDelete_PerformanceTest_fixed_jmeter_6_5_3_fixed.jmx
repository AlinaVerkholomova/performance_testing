        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Prepare Soft Delete Data" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
def ids = vars.get(&apos;USER_IDS&apos;).split(&apos;,&apos;).collect { it.trim() }.findAll { it }
if (ids.isEmpty()) {
    throw new IllegalStateException(&apos;USER_IDS must contain at least one existing active user_id&apos;)
}
def userId = ids[ctx.getThreadNum() % ids.size()]
vars.put(&apos;user_id&apos;, userId)
vars.put(&apos;user_status&apos;, &apos;deactivated&apos;)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PATCH /api/v1/users/{user_id}" enabled="true">
          <stringProp name="HTTPSampler.path">/api/v1/users/${user_id}</stringProp>
          <stringProp name="HTTPSampler.method">PATCH</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
  &quot;status&quot;: &quot;${user_status}&quot;&#xd;
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert PATCH 2xx Response" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def rc = prev.getResponseCode()
if (!(rc ==~ /2\d\d/)) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Expected HTTP 2xx for PATCH /api/v1/users/{user_id} but got ${rc}&quot;)
}
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223Assertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Aggregate PATCH Metrics" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import java.util.concurrent.atomic.LongAdder
import java.util.concurrent.atomic.AtomicLong

LongAdder total = props.get(&apos;delete.total&apos;) as LongAdder
LongAdder errors = props.get(&apos;delete.errors&apos;) as LongAdder
AtomicLong maxTime = props.get(&apos;delete.max&apos;) as AtomicLong

total.increment()
if (!prev.isSuccessful()) {
    errors.increment()
}

long sampleTime = prev.getTime()
while (true) {
    long cur = maxTime.get()
    if (cur &gt;= sampleTime) { break }
    if (maxTime.compareAndSet(cur, sampleTime)) { break }
}
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="TearDown - Validate NFRs" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Evaluate Soft Delete NFRs">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import java.util.concurrent.atomic.LongAdder
import java.util.concurrent.atomic.AtomicLong

LongAdder total = props.get(&apos;delete.total&apos;) as LongAdder
LongAdder errors = props.get(&apos;delete.errors&apos;) as LongAdder
AtomicLong maxTime = props.get(&apos;delete.max&apos;) as AtomicLong

long totalCount = total != null ? total.sum() : 0L
long errorCount = errors != null ? errors.sum() : 0L
long maxResponseTime = maxTime != null ? maxTime.get() : 0L

double successRate = totalCount &gt; 0 ? ((totalCount - errorCount) * 100.0d / totalCount) : 0.0d

boolean maxPass = maxResponseTime &lt;= 500L
boolean successPass = successRate &gt;= 98.0d

def sb = new StringBuilder()
sb.append(&apos;═══════════════════════════════════════════════\n&apos;)
sb.append(&apos;  NFR VALIDATION REPORT – Soft Delete PerfTest\n&apos;)
sb.append(&apos;═══════════════════════════════════════════════\n&apos;)
sb.append(&quot;  Total PATCH samples     : ${totalCount}\n&quot;)
sb.append(&quot;  Failed PATCH samples    : ${errorCount}\n&quot;)
sb.append(String.format(&apos;  Success rate            : %.2f%%  (target: &gt;= 98.0%%)  [%s]\n&apos;,
          successRate, successPass ? &apos;PASS&apos; : &apos;FAIL&apos;))
sb.append(&quot;  Max response time       : ${maxResponseTime} ms  (target: &lt;= 500 ms)  [${maxPass ? &apos;PASS&apos; : &apos;FAIL&apos;}]\n&quot;)
sb.append(&apos;═══════════════════════════════════════════════\n&apos;)
sb.append(&quot;  OVERALL NFR RESULT      : ${(maxPass &amp;&amp; successPass) ? &apos;PASS&apos; : &apos;FAIL&apos;}\n&quot;)
sb.append(&apos;═══════════════════════════════════════════════\n&apos;)
def summary = sb.toString()

SampleResult.setResponseData(summary, &apos;UTF-8&apos;)
log.info(summary)
System.out.println(summary)

if (totalCount == 0L) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&apos;500&apos;)
    SampleResult.setResponseMessage(&apos;No PATCH samples were collected&apos;)
    throw new AssertionError(&apos;No PATCH samples were collected for /api/v1/users/{user_id}&apos;)
}

if (!(maxPass &amp;&amp; successPass)) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&apos;500&apos;)
    SampleResult.setResponseMessage(&apos;NFR validation failed&apos;)
    throw new AssertionError(summary)
}

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&apos;200&apos;)
SampleResult.setResponseMessage(&apos;All NFR thresholds passed&apos;)</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
