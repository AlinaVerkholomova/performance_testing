    if (uid &amp;&amp; uid != &quot;null&quot;) {
        def list = props.get(&quot;deactivated_user_ids&quot;)
        if (list != null) list.add(uid)
    }
    // Mark this VU as done so the IfController skips on subsequent iterations
}
