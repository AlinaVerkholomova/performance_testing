            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert: deactivated user absent from /users/active" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
def uid          = vars.get(&quot;user_id&quot;)
def responseBody = prev.getResponseDataAsString()

if (!uid || uid == &quot;null&quot;) {
    // No user_id available – skip integrity check for this iteration
    AssertionResult.setResultForNull(false)
    return
}

// Check both the raw string and common JSON representations
def found = responseBody.contains(&quot;\&quot;${uid}\&quot;&quot;) ||
            responseBody.contains(&quot;&apos;${uid}&apos;&quot;)  ||
            responseBody.contains(uid)

if (found) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        &quot;DATA INTEGRITY BREACH: Deactivated user &apos;${uid}&apos; still appears in GET /users/active response&quot;
    )
} else {
    AssertionResult.setFailure(false)
}
                </stringProp>
