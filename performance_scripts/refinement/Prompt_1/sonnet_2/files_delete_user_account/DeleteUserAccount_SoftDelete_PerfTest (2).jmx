        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="NFR Validation – Max RT &amp; Success Rate">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// ─────────────────────────────────────────────────────────────────────────────
// NFR Threshold Validation (post-run)
//
// Reads results/summary_report.csv and validates:
//   1. Max Response Time for all PATCH soft-delete samples &lt;= 500 ms
//   2. Success Rate for all PATCH soft-delete samples      &gt;= 98 %
//
// Uses an RFC 4180-compliant CSV tokenizer so commas inside quoted
// response-message fields do not corrupt column indexing.
// ─────────────────────────────────────────────────────────────────────────────

// ── RFC 4180-compliant CSV tokenizer ─────────────────────────────────────────
def parseCsvLine = { String line -&gt;
    def fields   = []
    def sb2      = new StringBuilder()
    boolean inQ  = false
    int i = 0
    while (i &lt; line.length()) {
        char c = line.charAt(i)
        if (inQ) {
            if (c == &apos;&quot;&apos; as char) {
                if (i + 1 &lt; line.length() &amp;&amp; line.charAt(i + 1) == &apos;&quot;&apos; as char) {
                    sb2.append(&apos;&quot;&apos;); i += 2
                } else { inQ = false; i++ }
            } else { sb2.append(c); i++ }
        } else {
            if (c == &apos;&quot;&apos; as char)       { inQ = true; i++ }
            else if (c == &apos;,&apos; as char)  { fields.add(sb2.toString()); sb2.setLength(0); i++ }
            else                        { sb2.append(c); i++ }
        }
    }
    fields.add(sb2.toString())
    return fields
}

def resultsFile = new File(&quot;results/summary_report.csv&quot;)
if (!resultsFile.exists()) {
    log.warn(&quot;NFR Validation: results/summary_report.csv not found – skipping&quot;)
    SampleResult.setResponseMessage(&quot;WARNING: results file not found – skipping NFR check&quot;)
    SampleResult.setSuccessful(true)
    return
}

def lines      = resultsFile.readLines()
def headerCols = parseCsvLine(lines[0]).collect { it.trim().toLowerCase() }

def labelIdx   = headerCols.indexOf(&quot;label&quot;)
def timeIdx    = headerCols.indexOf(&quot;elapsed&quot;)
def successIdx = headerCols.indexOf(&quot;success&quot;)

if (labelIdx == -1 || timeIdx == -1 || successIdx == -1) {
    log.warn(&quot;NFR Validation: required CSV columns not found: &quot; + headerCols)
    SampleResult.setResponseMessage(&quot;WARNING: CSV column mapping failed&quot;)
    SampleResult.setSuccessful(true)
    return
}

long   maxRt   = 0L
int    total   = 0
int    failures = 0
int    minCols = Math.max(labelIdx, Math.max(timeIdx, successIdx)) + 1

lines.drop(1).each { line -&gt;
    if (!line.trim()) return
    def cols = parseCsvLine(line)
    if (cols.size() &lt; minCols) return
    def label = cols[labelIdx]?.trim()
    if (!label?.contains(&quot;PATCH&quot;) &amp;&amp; !label?.contains(&quot;TX-01&quot;) &amp;&amp;
        !label?.contains(&quot;soft delete&quot;)) return

    total++
    try {
        def rt = cols[timeIdx]?.trim()?.toLong()
        if (rt != null &amp;&amp; rt &gt; maxRt) maxRt = rt
    } catch (e) { /* skip malformed */ }

    def success = cols[successIdx]?.trim()?.toLowerCase()
    if (success == &quot;false&quot;) failures++
}

if (total == 0) {
    log.warn(&quot;NFR Validation: no PATCH samples found in results CSV&quot;)
    SampleResult.setResponseMessage(&quot;WARNING: no PATCH samples found&quot;)
    SampleResult.setSuccessful(true)
    return
}

double successRate  = ((total - failures) / (double) total) * 100.0
long   nfrMaxRt     = (vars?.get(&quot;NFR_MAX_RT_MS&quot;)?.toLong()         ?: 500L)
double nfrSuccRate  = (vars?.get(&quot;NFR_SUCCESS_RATE_PCT&quot;)?.toDouble() ?: 98.0)

boolean rtPass  = maxRt &lt;= nfrMaxRt
boolean srPass  = successRate &gt;= nfrSuccRate

def deactivatedList  = props.get(&quot;deactivated_user_ids&quot;)
int deactivatedCount = deactivatedList ? deactivatedList.size() : 0

def sb = new StringBuilder()
sb.append(&quot;═══════════════════════════════════════════════\n&quot;)
sb.append(&quot;  NFR VALIDATION REPORT – Soft Delete PerfTest\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════\n&quot;)
sb.append(&quot;  Total PATCH samples     : ${total}\n&quot;)
sb.append(&quot;  Failed PATCH samples    : ${failures}\n&quot;)
sb.append(&quot;  Success rate            : ${String.format(&apos;%.2f&apos;, successRate)}%  &quot;)
sb.append(&quot;(target: &gt;= ${nfrSuccRate}%)  [${srPass ? &apos;PASS&apos; : &apos;FAIL&apos;}]\n&quot;)
sb.append(&quot;  Max response time       : ${maxRt} ms  &quot;)
sb.append(&quot;(target: &lt;= ${nfrMaxRt} ms)  [${rtPass ? &apos;PASS&apos; : &apos;FAIL&apos;}]\n&quot;)
sb.append(&quot;  Deactivated users reg.  : ${deactivatedCount}\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════\n&quot;)
sb.append(&quot;  OVERALL NFR RESULT      : ${(rtPass &amp;&amp; srPass) ? &apos;PASS&apos; : &apos;FAIL&apos;}\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════\n&quot;)

log.info(sb.toString())
SampleResult.setResponseData(sb.toString().getBytes(&quot;UTF-8&quot;))
SampleResult.setResponseMessage(sb.toString())
SampleResult.setSuccessful(rtPass &amp;&amp; srPass)

if (!rtPass) {
    log.error(&quot;NFR BREACH: Max response time = ${maxRt}ms exceeds threshold of ${nfrMaxRt}ms&quot;)
}
if (!srPass) {
    log.error(&quot;NFR BREACH: Success rate = ${String.format(&apos;%.2f&apos;, successRate)}% below threshold of ${nfrSuccRate}%&quot;)
}
          </stringProp>
