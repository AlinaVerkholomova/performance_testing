        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init – results dir + shared collections" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
new File(&quot;results&quot;).mkdirs()

// Thread-safe metric accumulators for post-run P90 / error-rate validation
props.put(&quot;put_rt_list&quot;,     Collections.synchronizedList([]))
props.put(&quot;put_total&quot;,       new java.util.concurrent.atomic.AtomicLong(0L))
props.put(&quot;put_errors&quot;,      new java.util.concurrent.atomic.AtomicLong(0L))
props.put(&quot;put_start_epoch&quot;, System.currentTimeMillis())

// Consistency check registry: maps product_id -&gt; last PUT payload (name+price+stock)
props.put(&quot;put_payload_registry&quot;, new java.util.concurrent.ConcurrentHashMap())

SampleResult.setResponseMessage(&quot;setUp complete&quot;)
SampleResult.setSuccessful(true)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
