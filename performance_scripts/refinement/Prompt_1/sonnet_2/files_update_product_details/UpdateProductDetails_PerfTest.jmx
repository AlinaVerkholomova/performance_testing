      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 – Resolve payload and auth" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// Cache-buster values
vars.put(&quot;TIMESTAMP&quot;,      String.valueOf(System.currentTimeMillis()))
vars.put(&quot;CORRELATION_ID&quot;, UUID.randomUUID().toString())

// Resolve auth token: prefer CSV column, fall back to global UDV
def token = vars.get(&quot;auth_token&quot;)
if (!token || token == &quot;null&quot; || token.isEmpty()) {
    token = vars.get(&quot;AUTH_TOKEN&quot;)
}
vars.put(&quot;RESOLVED_TOKEN&quot;, token)

// ── Resolve PUT payload fields ────────────────────────────────────────────────
// Prefer CSV-supplied values; fall back to NFR-specified defaults.
// Price and stock are randomised within realistic ranges to generate
// varied write workloads and to make GET consistency assertions meaningful.

def csvName  = vars.get(&quot;p_name&quot;)
def csvDesc  = vars.get(&quot;p_description&quot;)
def csvPrice = vars.get(&quot;p_price&quot;)
def csvStock = vars.get(&quot;p_stock&quot;)

def rng = new Random()

// Product name variants (rotated to diversify write traffic)
def namePool = [
    &quot;Wireless Headphones&quot;,
    &quot;Noise-Cancelling Headphones&quot;,
    &quot;Over-Ear Headphones Pro&quot;,
    &quot;Studio Monitor Headphones&quot;,
    &quot;Bluetooth Headphones X1&quot;
]
def resolvedName = (csvName &amp;&amp; csvName != &quot;null&quot; &amp;&amp; !csvName.isEmpty())
    ? csvName
    : namePool[rng.nextInt(namePool.size())]

def resolvedDesc = (csvDesc &amp;&amp; csvDesc != &quot;null&quot; &amp;&amp; !csvDesc.isEmpty())
    ? csvDesc
    : &quot;Noise-cancelling over-ear headphones&quot;

// Price: CSV value or randomised between 49.99 and 199.99
def resolvedPrice = (csvPrice &amp;&amp; csvPrice != &quot;null&quot; &amp;&amp; !csvPrice.isEmpty())
    ? csvPrice
    : String.format(&quot;%.2f&quot;, 49.99 + rng.nextDouble() * 150.0)

// Stock: CSV value or randomised between 10 and 200
def resolvedStock = (csvStock &amp;&amp; csvStock != &quot;null&quot; &amp;&amp; !csvStock.isEmpty())
    ? csvStock
    : String.valueOf(10 + rng.nextInt(191))

vars.put(&quot;P_NAME&quot;,        resolvedName)
vars.put(&quot;P_DESCRIPTION&quot;, resolvedDesc)
vars.put(&quot;P_PRICE&quot;,       resolvedPrice)
vars.put(&quot;P_STOCK&quot;,       resolvedStock)

// Persist payload snapshot into shared registry keyed by product_id
// (used by GET consistency assertion post-processor)
def pid = vars.get(&quot;product_id&quot;)
if (pid &amp;&amp; pid != &quot;null&quot;) {
    def registry = props.get(&quot;put_payload_registry&quot;)
    if (registry != null) {
        registry.put(pid, [
            name  : resolvedName,
            price : resolvedPrice,
            stock : resolvedStock
        ])
    }
}
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
