            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 – Accumulate PUT metrics" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
props.get(&quot;put_rt_list&quot;)?.add(prev.getTime())
props.get(&quot;put_total&quot;)?.incrementAndGet()
if (!prev.isSuccessful()) props.get(&quot;put_errors&quot;)?.incrementAndGet()
