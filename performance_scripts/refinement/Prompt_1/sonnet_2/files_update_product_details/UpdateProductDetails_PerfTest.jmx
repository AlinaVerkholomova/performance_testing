      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown TG – NFR Threshold Validation" enabled="true">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">stoptest</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="NFR Validation – P90 and Error Rate" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// ─────────────────────────────────────────────────────────────────────────────
// NFR Post-Run Validation
//
// Validates PUT /api/v1/products/{product_id} against:
//   1. P90 Response Time &lt;= 700 ms
//   2. Error Rate        &lt;  1 %
//
// Primary:  in-memory metric collections (accumulated by JSR223PostProcessor)
// Fallback: results/summary_report.csv
// ─────────────────────────────────────────────────────────────────────────────

long   nfrP90Ms  = (vars?.get(&quot;NFR_P90_MS&quot;)?.toLong()           ?: 700L)
double nfrErrPct = (vars?.get(&quot;NFR_ERROR_RATE_PCT&quot;)?.toDouble() ?: 1.0)

def    rtList     = props.get(&quot;put_rt_list&quot;)
def    totalAt    = props.get(&quot;put_total&quot;)
def    errorsAt   = props.get(&quot;put_errors&quot;)

long   total      = 0L
long   errors     = 0L
long   p90        = 0L
boolean usedCsv   = false

if (rtList != null &amp;&amp; !rtList.isEmpty()) {
    // ── In-memory path ──────────────────────────────────────────────────────
    def snapshot = new ArrayList(rtList)
    total  = totalAt?.get()  ?: (long) snapshot.size()
    errors = errorsAt?.get() ?: 0L

    snapshot.sort()
    int p90Idx = (int) Math.ceil(0.90 * snapshot.size()) - 1
    p90 = snapshot[Math.max(0, p90Idx)]

} else {
    // ── CSV fallback ─────────────────────────────────────────────────────────
    usedCsv = true
    def f = new File(&quot;results/summary_report.csv&quot;)
    if (!f.exists()) {
        log.warn(&quot;NFR Validation: no metrics source available – skipping&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: no metrics source found&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    def lines      = f.readLines()
    def header     = lines[0].split(&quot;,&quot;).collect { it.trim().toLowerCase() }
    def labelIdx   = header.indexOf(&quot;label&quot;)
    def timeIdx    = header.indexOf(&quot;elapsed&quot;)
    def successIdx = header.indexOf(&quot;success&quot;)

    if (labelIdx == -1 || timeIdx == -1) {
        log.warn(&quot;NFR Validation: required columns absent in CSV&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: CSV column mapping failed&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    def times = []
    lines.drop(1).each { line -&gt;
        if (!line.trim()) return
        def cols  = line.split(&quot;,&quot;, -1)
        def label = cols[labelIdx]?.trim()
        if (!label?.toUpperCase()?.contains(&quot;PUT&quot;) &amp;&amp;
            !label?.contains(&quot;TX-01&quot;) &amp;&amp;
            !label?.contains(&quot;products&quot;)) return
        total++
        try { def rt = cols[timeIdx]?.trim()?.toLong(); if (rt != null) times &lt;&lt; rt } catch (e) {}
        if (cols[successIdx]?.trim()?.toLowerCase() == &quot;false&quot;) errors++
    }

    if (total == 0) {
        log.warn(&quot;NFR Validation: no PUT samples found in CSV&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: no PUT product samples found&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    times.sort()
    int p90Idx = (int) Math.ceil(0.90 * times.size()) - 1
    p90 = times[Math.max(0, p90Idx)]
}

double errorRatePct = total &gt; 0 ? (errors / (double) total) * 100.0 : 0.0

boolean p90Pass = p90          &lt;= nfrP90Ms
boolean errPass = errorRatePct  &lt; nfrErrPct

def sb = new StringBuilder()
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
sb.append(&quot;  NFR VALIDATION REPORT – Update Product Details\n&quot;)
sb.append(&quot;  PUT /api/v1/products/{product_id}   (source: ${usedCsv ? &apos;CSV&apos; : &apos;in-memory&apos;})\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
sb.append(&quot;  Total PUT samples   : ${total}\n&quot;)
sb.append(&quot;  Failed PUT samples  : ${errors}\n&quot;)
sb.append(String.format(&quot;  Error rate          : %.3f%%  (target: &lt; %.1f%%)   [%s]\n&quot;,
          errorRatePct, nfrErrPct, errPass ? &quot;PASS&quot; : &quot;FAIL&quot;))
sb.append(&quot;  P90 response time   : ${p90} ms  (target: &lt;= ${nfrP90Ms} ms)   [${p90Pass ? &apos;PASS&apos; : &apos;FAIL&apos;}]\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
boolean overall = p90Pass &amp;&amp; errPass
sb.append(&quot;  OVERALL NFR RESULT  : ${overall ? &apos;PASS&apos; : &apos;FAIL&apos;}\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)

log.info(sb.toString())
SampleResult.setResponseData(sb.toString().getBytes(&quot;UTF-8&quot;))
SampleResult.setResponseMessage(sb.toString())
SampleResult.setSuccessful(overall)

if (!p90Pass) log.error(&quot;NFR BREACH: P90 = ${p90}ms exceeds threshold of ${nfrP90Ms}ms&quot;)
if (!errPass) log.error(String.format(&quot;NFR BREACH: Error rate = %.3f%% exceeds threshold of %.1f%%&quot;, errorRatePct, nfrErrPct))
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert: All NFR targets met" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="2150174">FAIL</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">NFR threshold breached – see sampler response body for details</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <boolProp name="Assertion.negate">true</boolProp>
          </ResponseAssertion>
