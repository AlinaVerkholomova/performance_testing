      </hashTree>
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown TG – NFR Threshold Validation">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">stoptest</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="NFR Validation – Avg RT, P95, Error Rate, Throughput">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// ─────────────────────────────────────────────────────────────────────────────
// NFR Post-Run Validation
// Primary source: in-memory metrics collected by JSR223PostProcessor.
// Fallback:       results/summary_report.csv (if props are unavailable).
// Validates all four NFR targets for POST /api/v1/orders/history.
// ─────────────────────────────────────────────────────────────────────────────

// ── Read thresholds ───────────────────────────────────────────────────────────
long   nfrAvgMs  = (vars?.get(&quot;NFR_AVG_RT_MS&quot;)?.toLong()          ?: 300L)
long   nfrP95Ms  = (vars?.get(&quot;NFR_P95_MS&quot;)?.toLong()             ?: 600L)
double nfrErrPct = (vars?.get(&quot;NFR_ERROR_RATE_PCT&quot;)?.toDouble()   ?: 0.5)
double nfrTpRps  = (vars?.get(&quot;NFR_THROUGHPUT_RPS&quot;)?.toDouble()   ?: 100.0)

// ── Prefer in-memory metrics (higher precision) ───────────────────────────────
def rtList       = props.get(&quot;order_history_rt_list&quot;)
def totalAtomic  = props.get(&quot;order_history_total&quot;)
def errAtomic    = props.get(&quot;order_history_errors&quot;)
def startEpoch   = props.get(&quot;order_history_start_epoch&quot;)

long   total     = 0L
long   errors    = 0L
long   avgRt     = 0L
long   p95       = 0L
double tpRps     = 0.0
boolean usedCsv  = false

if (rtList != null &amp;&amp; !rtList.isEmpty()) {
    def snapshot = new ArrayList(rtList)
    total  = totalAtomic?.get() ?: snapshot.size()
    errors = errAtomic?.get()   ?: 0L

    // Average
    avgRt = (long) snapshot.sum() / snapshot.size()

    // P95
    snapshot.sort()
    int p95Idx = (int) Math.ceil(0.95 * snapshot.size()) - 1
    p95 = snapshot[Math.max(0, p95Idx)]

    // Throughput (req/s over actual elapsed duration)
    if (startEpoch) {
        double elapsedSec = (System.currentTimeMillis() - (long) startEpoch) / 1000.0
        tpRps = elapsedSec &gt; 0 ? total / elapsedSec : 0.0
    }
} else {
    // ── Fallback: parse CSV ───────────────────────────────────────────────────
    usedCsv = true
    def resultsFile = new File(&quot;results/summary_report.csv&quot;)
    if (!resultsFile.exists()) {
        log.warn(&quot;NFR Validation: no in-memory data and no CSV found – skipping&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: no metrics source available&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    def lines      = resultsFile.readLines()
    def header     = lines[0].split(&quot;,&quot;).collect { it.trim().toLowerCase() }
    def labelIdx   = header.indexOf(&quot;label&quot;)
    def timeIdx    = header.indexOf(&quot;elapsed&quot;)
    def successIdx = header.indexOf(&quot;success&quot;)
    def tsIdx      = header.indexOf(&quot;timestamp&quot;)

    if (timeIdx == -1 || labelIdx == -1) {
        log.warn(&quot;NFR Validation: required columns missing in CSV header&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: CSV column mapping failed&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    def times  = []
    long minTs = Long.MAX_VALUE
    long maxTs = Long.MIN_VALUE

    lines.drop(1).each { line -&gt;
        if (!line.trim()) return
        def cols  = line.split(&quot;,&quot;, -1)
        def label = cols[labelIdx]?.trim()
        if (!label?.contains(&quot;orders/history&quot;) &amp;&amp; !label?.contains(&quot;TX-01&quot;)) return
        total++
        try {
            def rt = cols[timeIdx]?.trim()?.toLong()
            if (rt != null) times &lt;&lt; rt
            if (tsIdx &gt;= 0) {
                def ts = cols[tsIdx]?.trim()?.toLong()
                if (ts != null) {
                    if (ts &lt; minTs) minTs = ts
                    if (ts &gt; maxTs) maxTs = ts
                }
            }
        } catch (e) {}
        if (cols[successIdx]?.trim()?.toLowerCase() == &quot;false&quot;) errors++
    }

    if (total == 0) {
        log.warn(&quot;NFR Validation: no matching samples in CSV&quot;)
        SampleResult.setResponseMessage(&quot;WARNING: no POST /orders/history samples found&quot;)
        SampleResult.setSuccessful(true)
        return
    }

    times.sort()
    avgRt = (long) times.sum() / times.size()
    int p95Idx = (int) Math.ceil(0.95 * times.size()) - 1
    p95 = times[Math.max(0, p95Idx)]

    if (minTs &lt; Long.MAX_VALUE &amp;&amp; maxTs &gt; Long.MIN_VALUE) {
        double elapsedSec = (maxTs - minTs) / 1000.0
        tpRps = elapsedSec &gt; 0 ? total / elapsedSec : 0.0
    }
}

// ── Compute error rate ─────────────────────────────────────────────────────────
double errorRatePct = total &gt; 0 ? (errors / (double) total) * 100.0 : 0.0

// ── Evaluate NFR gates ─────────────────────────────────────────────────────────
boolean avgPass  = avgRt  &lt;= nfrAvgMs
boolean p95Pass  = p95    &lt;= nfrP95Ms
boolean errPass  = errorRatePct &lt; nfrErrPct
boolean tpPass   = tpRps  &gt;= nfrTpRps

// ── Report ─────────────────────────────────────────────────────────────────────
def sb = new StringBuilder()
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
sb.append(&quot;  NFR VALIDATION REPORT – Retrieve Order History\n&quot;)
sb.append(&quot;  POST /api/v1/orders/history   (source: ${usedCsv ? &apos;CSV&apos; : &apos;in-memory&apos;})\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
sb.append(&quot;  Total samples       : ${total}\n&quot;)
sb.append(&quot;  Failed samples      : ${errors}\n&quot;)
sb.append(String.format(&quot;  Error rate          : %.3f%%  (target: &lt; %.1f%%)   [%s]\n&quot;,
          errorRatePct, nfrErrPct, errPass ? &quot;PASS&quot; : &quot;FAIL&quot;))
sb.append(&quot;  Avg response time   : ${avgRt} ms  (target: &lt;= ${nfrAvgMs} ms)   [${avgPass ? &apos;PASS&apos; : &apos;FAIL&apos;}]\n&quot;)
sb.append(&quot;  P95 latency         : ${p95} ms  (target: &lt;= ${nfrP95Ms} ms)   [${p95Pass ? &apos;PASS&apos; : &apos;FAIL&apos;}]\n&quot;)
sb.append(String.format(&quot;  Throughput          : %.2f req/s  (target: &gt;= %.0f req/s)   [%s]\n&quot;,
          tpRps, nfrTpRps, tpPass ? &quot;PASS&quot; : &quot;FAIL&quot;))
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)
boolean overall = avgPass &amp;&amp; p95Pass &amp;&amp; errPass &amp;&amp; tpPass
sb.append(&quot;  OVERALL NFR RESULT  : ${overall ? &apos;PASS&apos; : &apos;FAIL&apos;}\n&quot;)
sb.append(&quot;═══════════════════════════════════════════════════════\n&quot;)

log.info(sb.toString())
SampleResult.setResponseData(sb.toString().getBytes(&quot;UTF-8&quot;))
SampleResult.setResponseMessage(sb.toString())
SampleResult.setSuccessful(overall)

if (!avgPass) log.error(&quot;NFR BREACH: Avg RT = ${avgRt}ms exceeds threshold of ${nfrAvgMs}ms&quot;)
if (!p95Pass) log.error(&quot;NFR BREACH: P95   = ${p95}ms exceeds threshold of ${nfrP95Ms}ms&quot;)
if (!errPass) log.error(String.format(&quot;NFR BREACH: Error rate = %.3f%% exceeds threshold of %.1f%%&quot;, errorRatePct, nfrErrPct))
if (!tpPass)  log.error(String.format(&quot;NFR BREACH: Throughput = %.2f req/s below threshold of %.0f req/s&quot;, tpRps, nfrTpRps))
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
