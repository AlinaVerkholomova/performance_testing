        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init – results dir + shared metrics">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
new File(&quot;results&quot;).mkdirs()

// Thread-safe collections for post-run NFR computation
props.put(&quot;order_history_rt_list&quot;,     Collections.synchronizedList([]))
props.put(&quot;order_history_total&quot;,       new java.util.concurrent.atomic.AtomicLong(0))
props.put(&quot;order_history_errors&quot;,      new java.util.concurrent.atomic.AtomicLong(0))
props.put(&quot;order_history_start_epoch&quot;, System.currentTimeMillis())

SampleResult.setResponseMessage(&quot;Initialisation complete&quot;)
SampleResult.setSuccessful(true)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
