        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 – Resolve payload variables">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// Cache-buster
vars.put(&quot;TIMESTAMP&quot;, String.valueOf(System.currentTimeMillis()))
vars.put(&quot;CORRELATION_ID&quot;, UUID.randomUUID().toString())

// Resolve auth token (optional)
def token = vars.get(&quot;AUTH_TOKEN&quot;)
vars.put(&quot;RESOLVED_TOKEN&quot;, (token &amp;&amp; token != &quot;STATIC_TOKEN_OR_LEAVE_EMPTY&quot;) ? token : &quot;&quot;)

// Resolve payload fields: prefer CSV row, fall back to defaults
def userId    = vars.get(&quot;csv_user_id&quot;)
def startDate = vars.get(&quot;csv_start_date&quot;)
def endDate   = vars.get(&quot;csv_end_date&quot;)
def status    = vars.get(&quot;csv_status&quot;)

vars.put(&quot;P_USER_ID&quot;,    (userId    &amp;&amp; userId    != &quot;null&quot;) ? userId    : &quot;user_789&quot;)
vars.put(&quot;P_START_DATE&quot;, (startDate &amp;&amp; startDate != &quot;null&quot;) ? startDate : &quot;2024-01-01&quot;)
vars.put(&quot;P_END_DATE&quot;,   (endDate   &amp;&amp; endDate   != &quot;null&quot;) ? endDate   : &quot;2024-12-31&quot;)
vars.put(&quot;P_STATUS&quot;,     (status    &amp;&amp; status    != &quot;null&quot;) ? status    : &quot;completed&quot;)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
