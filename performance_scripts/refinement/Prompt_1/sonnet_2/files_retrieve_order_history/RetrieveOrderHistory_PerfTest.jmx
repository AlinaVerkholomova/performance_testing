            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 – Collect RT metric">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
def rtList  = props.get(&quot;order_history_rt_list&quot;)
def total   = props.get(&quot;order_history_total&quot;)
def errors  = props.get(&quot;order_history_errors&quot;)

if (rtList != null) rtList.add(prev.getTime())
if (total  != null) total.incrementAndGet()
if (errors != null &amp;&amp; !prev.isSuccessful()) errors.incrementAndGet()
              </stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
