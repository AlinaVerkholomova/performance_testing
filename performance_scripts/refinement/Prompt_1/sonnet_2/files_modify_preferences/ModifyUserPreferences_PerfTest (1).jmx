      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 – Set Iteration Variables" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// Unique timestamp to prevent any CDN / reverse-proxy caching
vars.put(&quot;TIMESTAMP&quot;, String.valueOf(System.currentTimeMillis()))

// Randomly alternate language to create realistic variation in payloads
def langs = [&quot;fr&quot;, &quot;en&quot;, &quot;de&quot;, &quot;es&quot;, &quot;it&quot;, &quot;pt&quot;]
def lang   = langs[new Random().nextInt(langs.size())]
vars.put(&quot;PREF_LANGUAGE&quot;, lang)

// Randomly toggle email_notifications
def emailNotif = (new Random().nextBoolean()) ? &quot;false&quot; : &quot;true&quot;
vars.put(&quot;EMAIL_NOTIFICATIONS&quot;, emailNotif)

// Resolve auth token: prefer CSV column, fall back to global variable
def token = vars.get(&quot;auth_token&quot;)
if (token == null || token.isEmpty() || token == &quot;null&quot;) {
    token = vars.get(&quot;AUTH_TOKEN&quot;)
}
vars.put(&quot;RESOLVED_TOKEN&quot;, token)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
