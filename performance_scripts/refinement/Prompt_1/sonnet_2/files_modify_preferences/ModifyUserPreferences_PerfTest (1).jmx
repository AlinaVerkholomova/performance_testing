            <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="Assert: Response Time &lt;= 2000ms (hard ceiling)" enabled="true">
              <stringProp name="DurationAssertion.duration">2000</stringProp>
