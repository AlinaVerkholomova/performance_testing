            </DurationAssertion>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract: returned_language and returned_email_notif" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
import groovy.json.JsonSlurper
def body = prev.getResponseDataAsString()
if (body) {
    try {
        def json = new JsonSlurper().parseText(body)
        vars.put(&quot;returned_language&quot;,   json?.language?.toString()            ?: &quot;EXTRACTION_FAILED&quot;)
        vars.put(&quot;returned_email_notif&quot;, json?.email_notifications?.toString() ?: &quot;EXTRACTION_FAILED&quot;)
    } catch (Exception e) {
        vars.put(&quot;returned_language&quot;,   &quot;EXTRACTION_FAILED&quot;)
        vars.put(&quot;returned_email_notif&quot;, &quot;EXTRACTION_FAILED&quot;)
    }
} else {
    vars.put(&quot;returned_language&quot;,   &quot;EXTRACTION_FAILED&quot;)
    vars.put(&quot;returned_email_notif&quot;, &quot;EXTRACTION_FAILED&quot;)
}
              </stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
