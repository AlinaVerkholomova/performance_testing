        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="NFR Validation – p95 &amp; Error Rate Check">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// ─────────────────────────────────────────────────────────────────────────────
// NFR Threshold Validation
// Reads results/summary_report.csv, extracts PATCH transaction rows,
// and asserts:
//   1. p95 response time  ≤ 400 ms
//   2. Error rate         &lt; 1 %
// ─────────────────────────────────────────────────────────────────────────────

def resultsFile = new File(&quot;results/summary_report.csv&quot;)
if (!resultsFile.exists()) {
    log.warn(&quot;NFR Validation: results/summary_report.csv not found – skipping post-hoc check&quot;)
    SampleResult.setResponseMessage(&quot;WARNING: results file not found&quot;)
    SampleResult.setSuccessful(true)
    return
}

// ── Parse CSV ──────────────────────────────────────────────────────────────
def lines     = resultsFile.readLines()
def header    = lines[0].split(&quot;,&quot;).collect { it.trim().toLowerCase() }

def tsIdx     = header.indexOf(&quot;timestamp&quot;)
def labelIdx  = header.indexOf(&quot;label&quot;)
def timeIdx   = header.indexOf(&quot;elapsed&quot;)       // response time ms
def successIdx = header.indexOf(&quot;success&quot;)
def codeIdx   = header.indexOf(&quot;responsecode&quot;)

if (timeIdx == -1 || labelIdx == -1) {
    log.warn(&quot;NFR Validation: Cannot locate required columns in CSV header&quot;)
    SampleResult.setResponseMessage(&quot;WARNING: CSV column mapping failed&quot;)
    SampleResult.setSuccessful(true)
    return
}

def patchTimes   = []
def patchTotal   = 0
def patchErrors  = 0

lines.drop(1).each { line -&gt;
    if (!line.trim()) return
    // Guard: skip rows with too few columns to avoid ArrayIndexOutOfBoundsException
    def cols = line.split(&quot;,&quot;, -1)
    int minRequired = [labelIdx, timeIdx, successIdx].findAll { it &gt;= 0 }.max() ?: 0
    if (cols.size() &lt;= minRequired) return
    def label = cols[labelIdx]?.trim()?.replace(&quot;\&quot;&quot;, &quot;&quot;)

    // Match on the PATCH transaction label
    if (label?.contains(&quot;PATCH&quot;) || label?.contains(&quot;TX-01&quot;)) {
        patchTotal++
        try {
            def rt = cols[timeIdx]?.trim()?.toLong()
            if (rt != null) patchTimes &lt;&lt; rt
        } catch (e) { /* skip malformed rows */ }

        // Null-safe success check
        if (successIdx &gt;= 0 &amp;&amp; successIdx &lt; cols.size()) {
            def success = cols[successIdx]?.trim()?.toLowerCase()
            if (success == &quot;false&quot;) patchErrors++
        }
    }
}

if (patchTotal == 0) {
    log.warn(&quot;NFR Validation: No PATCH samples found in results CSV&quot;)
    SampleResult.setResponseMessage(&quot;WARNING: no PATCH samples in results&quot;)
    SampleResult.setSuccessful(true)
    return
}

// ── Compute p95 ────────────────────────────────────────────────────────────
patchTimes.sort()
int p95Idx = (int) Math.ceil(0.95 * patchTimes.size()) - 1
long p95   = patchTimes[Math.max(0, p95Idx)]

// ── Compute error rate ─────────────────────────────────────────────────────
double errorRatePct = (patchErrors / (double) patchTotal) * 100.0

// ── NFR thresholds ─────────────────────────────────────────────────────────
long   nfrP95Ms      = (vars?.get(&quot;NFR_P95_MS&quot;)?.toLong()         ?: 400L)
double nfrErrRatePct = (vars?.get(&quot;NFR_ERROR_RATE_PCT&quot;)?.toDouble() ?: 1.0)

def sb = new StringBuilder()
sb.append(&quot;NFR Validation Results\n&quot;)
sb.append(&quot;  Total PATCH samples : ${patchTotal}\n&quot;)
sb.append(&quot;  Error count         : ${patchErrors}\n&quot;)
sb.append(&quot;  Error rate          : ${String.format(&apos;%.2f&apos;, errorRatePct)}%  (target: &lt; ${nfrErrRatePct}%)\n&quot;)
sb.append(&quot;  p95 response time   : ${p95} ms  (target: &lt;= ${nfrP95Ms} ms)\n&quot;)

boolean p95Pass  = p95 &lt;= nfrP95Ms
boolean errPass  = errorRatePct &lt; nfrErrRatePct

sb.append(&quot;\n  [p95]        : ${p95Pass  ? &apos;PASS&apos; : &apos;FAIL&apos;}\n&quot;)
sb.append(&quot;  [error rate] : ${errPass  ? &apos;PASS&apos; : &apos;FAIL&apos;}\n&quot;)

log.info(sb.toString())
SampleResult.setResponseData(sb.toString().getBytes(&quot;UTF-8&quot;))
SampleResult.setResponseMessage(sb.toString())
SampleResult.setSuccessful(p95Pass &amp;&amp; errPass)

if (!p95Pass) {
    log.error(&quot;NFR BREACH: p95 = ${p95}ms exceeds threshold of ${nfrP95Ms}ms&quot;)
}
if (!errPass) {
    log.error(&quot;NFR BREACH: error rate = ${String.format(&apos;%.2f&apos;, errorRatePct)}% exceeds threshold of ${nfrErrRatePct}%&quot;)
}
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert: NFR thresholds met" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="2150174">FAIL</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">NFR threshold breached – see sampler response for details</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <boolProp name="Assertion.negate">true</boolProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
